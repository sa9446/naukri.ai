# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/naukri_cv_db"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ─── OpenAI (AI Layer) ──────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ─── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── File Upload ────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ─── Job Scraper ────────────────────────────────────────────
# Rate limiting for scrapers (requests per minute)
SCRAPER_RATE_LIMIT=10
SCRAPER_DELAY_MS=2000

# ─── Matching ───────────────────────────────────────────────
# Minimum match score to return (0.0 - 1.0)
MIN_MATCH_SCORE=0.80

# Weights (must sum to 1.0)
WEIGHT_SKILLS=0.40
WEIGHT_EXPERIENCE=0.25
WEIGHT_DOMAIN=0.20
WEIGHT_BEHAVIORAL=0.15
