# ─── Ollama Local Inference Server ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_FALLBACK_MODEL=phi3:mini
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# ─── Embedding Model (runs fully offline via sentence-transformers) ─
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Alternatives: all-MiniLM-L6-v2, all-mpnet-base-v2

# ─── FastAPI Service ──────────────────────────────────────────
AI_ENGINE_PORT=8000
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_SECRET=change-me-to-a-random-secret

# ─── Node.js Backend Auth ─────────────────────────────────────
# The Node.js backend uses this key to call the AI engine
INTERNAL_API_KEY=internal-service-key-change-in-production

# ─── Model Inference Settings ────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_CONTEXT_WINDOW=8192

# ─── Scoring Weights (must sum to 1.0) ───────────────────────
WEIGHT_SKILLS=0.40
WEIGHT_EXPERIENCE=0.25
WEIGHT_DOMAIN=0.20
WEIGHT_BEHAVIORAL=0.15
MIN_MATCH_SCORE=0.80

# ─── Rule-Based Fallback ─────────────────────────────────────
# If Ollama is unavailable, fall back to rule-based extraction
USE_RULE_FALLBACK=true
